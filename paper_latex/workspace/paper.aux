\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Arrhenius plot for a representative phi-4/MMLU-Pro instance ($R^2 = 0.985$, $E_a = 0.127$, $\log A = -0.091$). \textit  {Left panel}: $\log P(\text  {correct}|T)$ plotted against $1/T$ over the temperature grid $\mathcal  {T} = \{0.05, 0.1, 0.2, 0.3, 0.5, 0.7, 1.0\}$; the linear Arrhenius fit ($-E_a/T + \log A$) is overlaid in red. \textit  {Right panel}: the same data in probability space ($P(\text  {correct})$ vs.\ $T$), showing the characteristic S-shaped rising limb. The slope magnitude $E_a$ is the inference activation energy; $T_\text  {thresh} = E_a/\ln (16) \approx 0.046$ marks the minimum temperature for BON-16 recovery.}}{4}{figure.2}\protected@file@percent }
\newlabel{fig:arrhenius-plot}{{2}{4}{Arrhenius plot for a representative phi-4/MMLU-Pro instance ($R^2 = 0.985$, $E_a = 0.127$, $\log A = -0.091$). \textit {Left panel}: $\log P(\text {correct}|T)$ plotted against $1/T$ over the temperature grid $\mathcal {T} = \{0.05, 0.1, 0.2, 0.3, 0.5, 0.7, 1.0\}$; the linear Arrhenius fit ($-E_a/T + \log A$) is overlaid in red. \textit {Right panel}: the same data in probability space ($P(\text {correct})$ vs.\ $T$), showing the characteristic S-shaped rising limb. The slope magnitude $E_a$ is the inference activation energy; $T_\text {thresh} = E_a/\ln (16) \approx 0.046$ marks the minimum temperature for BON-16 recovery}{figure.2}{}}
